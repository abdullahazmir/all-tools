PORT=5000
NODE_ENV=development
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/toolbazaar
CLIENT_URL=http://localhost:3000
# Public URL of this server itself — used as BetterAuth's baseURL.
# In production, set this to the deployed backend URL (e.g. https://toolbazaar-api.onrender.com)
SERVER_URL=http://localhost:5000

BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

GEMINI_API_KEY=
